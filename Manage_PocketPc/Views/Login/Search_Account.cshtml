@using Manage_PocketPc.Models
@model IEnumerable<LoginUser>

@{
    ViewData["Title"] = "Tìm kiếm User";
}

<div class="p-3">
    <div class="d-flex align-items-center justify-content-between gap-2">
        <a asp-controller="Login"
           asp-action="Create"
           class="btn btn-success btn-sm text-white fw-bold btn-rounded">
            Thêm tài khoản
        </a>

        <div class="input-group" style="max-width: 320px;">
            <form method="post" asp-controller="Login" asp-action="Search_Account" class="d-flex w-100">
                <input type="text" class="form-control form-control-sm me-3" style="width :200px;" placeholder="Nhập mã nhân viên..." name="User_code" value="@(ViewBag.User ?? "")">
                <button class="btn btn-primary btn-sm text-white fw-bold" type="submit">
                    Tìm kiếm
                </button>
            </form>
        </div>
    </div>
</div>

<div class="card product-card shadow-sm border-0">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0 fw-semibold">Danh Sách tài khoản</h5>
    </div>

    <div class="card-body pt-0">
        <!-- Khung cuộn dọc -->
        <div class="table-scroll-y">
            <table class="table table-hover align-middle mb-0 ik-table">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="min-width:140px;">Mã nhân viên</th>
                        <th style="min-width:200px;">Mật khẩu</th>
                        <th style="min-width:200px;">Bộ phận</th>
                        <th style="width:220px;" class="text-center">CHỨC NĂNG</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var p in Model)
                        {
                            <tr>
                                <td>@p.user_code</td>
                                <td>@p.password</td>
                                <td>@p.department</td>
                                <td class="text-center">
                                    <div class="d-inline-flex align-items-center gap-2">
                                        <a asp-controller="Login"
                                           asp-action="Update"
                                           asp-route-user="@p.user_code"
                                           class="btn btn-info btn-sm text-white fw-bold btn-rounded">
                                            Sửa
                                        </a>
                                        <form id="delete_@p.user_code"
                                              asp-controller="Login"
                                              asp-action="Delete"
                                              method="post"
                                              class="d-inline">
                                            <input type="hidden" name="user" value="@p.user_code" />
                                            <button type="button"
                                                    class="btn btn-danger btn-sm text-white fw-bold btn-rounded"
                                                    onclick="confirmDelete('delete_@p.user_code')">
                                                Xóa
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
            </table>
        </div>
    </div>
</div>