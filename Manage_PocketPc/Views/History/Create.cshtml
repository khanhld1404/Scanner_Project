@using Manage_PocketPc.Models;
@model UpdateHistory

@{
    ViewData["Title"] = "Create_History";
}

<h4>Thêm phiên bản mới</h4>

<div class="col-md-9">
    <form asp-controller="History" asp-action="Create" id="formCreate">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <input type="file" id="fileInput" name="uploadFiles" hidden multiple>

            <button type="button" class="btn btn-primary"
                    onclick="document.getElementById('fileInput').click()">
                Chọn file
            </button>

            <div id="fileName" class="text-muted mt-2"></div>
        </div>

        <div class="mb-3">
            <label class="form-label">Nhập phiên bản:</label>
            <input asp-for="Version" class="form-control" />
            <span asp-validation-for="Version" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Cập nhật bởi :</label>
            <input asp-for="Person" class="form-control" />
            <span asp-validation-for="Person" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Nội dung cập nhật :</label>
            <textarea asp-for="Contents" class="form-control"> </textarea>
            <span asp-validation-for="Contents" class="text-danger"></span>
        </div>


        <button type="submit" class="btn btn-success btn-sm fw-bold">Lưu</button>
        <a asp-controller="History" asp-action="Index" class="btn btn-secondary btn-sm">Quay lại</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}