<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manage_PocketPc</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Manage_PocketPc.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Login" asp-action="Logout">Quản lý dữ liệu Pocket PC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="IK" asp-action="IK">Quản lý IK</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="RFC" asp-action="RFC">Quản lý RFC</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Login" asp-action="Login">Quản lý tài khoản</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Connect" asp-action="Index">Quản lý kết nối</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="History" asp-action="Index">Quản lý phiên bản</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Scan" asp-action="Index">Dữ liệu scan</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted ">
        <div class="container">
            Chương trình quản lý pocket pc được phát triển bới Khánh 
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function() {
          const text_error  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["error"] ?? ""));
          const text_success = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["success"] ?? ""));
          if (text_error.trim() != '') {
            Swal.fire({
              icon: 'warning', //success, error, warning, info, question
              title: "Cảnh báo",
              text: text_error,
              confirmButtonText: 'OK'
            });
          }else if (text_success.trim() != '') {
            Swal.fire({
              icon: 'success', // success, error, warning, info, question
              title: "Thông báo",
              text: text_success,
              confirmButtonText: 'OK'
            });
          }
        })();
    </script>
    <script>
        function confirmDelete(formId) {
          Swal.fire({
                title: "Bạn có chắc muốn xóa?",
                text: "Bạn sẽ không thể phục hồi lại thông tin sau khi xóa!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Có, xóa nó",
                cancelButtonText: "Quay lại"
          }).then((result) => {
            if (result.isConfirmed) {
              document.getElementById(formId).submit(); 
            }
          });
        }
    </script>
    <script>
        document.getElementById("btnCreate").addEventListener("click", async () => {

            const { value: note } = await Swal.fire({
                title: "Nhập mô tả",
                input: "text",
                inputPlaceholder: "mô tả của bạn...",
                showCancelButton: true,
                confirmButtonText: "OK",
                cancelButtonText: "Hủy",
                inputValidator: (value) => {
                    if (!value || !value.trim()) {
                        return "Vui lòng nhập nội dung!";
                    }
                }
            });

            if (note) {
                // Tạo input hidden để gửi kèm form
                let form = document.getElementById("formCreate");
                let hidden = document.createElement("input");
                hidden.type = "hidden";
                hidden.name = "Note";     // tên param ở action
                hidden.value = note;
                form.appendChild(hidden);

                form.submit();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
